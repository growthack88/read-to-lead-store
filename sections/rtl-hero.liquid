{% comment %} RTL Custom Hero Section — Read to Lead {% endcomment %}

<section class="rtl-hero" id="rtl-hero">
  <div class="rtl-hero__bg-pattern"></div>
  <div class="rtl-hero__container">
    <div class="rtl-hero__content">
      <span class="rtl-hero__badge">{{ section.settings.badge_text }}</span>
      <h1 class="rtl-hero__title">{{ section.settings.title }}</h1>
      <p class="rtl-hero__subtitle">{{ section.settings.subtitle }}</p>
      <div class="rtl-hero__ctas">
        {% if section.settings.cta_primary_text != blank %}
        <a href="{{ section.settings.cta_primary_link }}" class="rtl-hero__btn rtl-hero__btn--primary">
          {{ section.settings.cta_primary_text }}
        </a>
        {% endif %}
        {% if section.settings.cta_secondary_text != blank %}
        <a href="{{ section.settings.cta_secondary_link }}" class="rtl-hero__btn rtl-hero__btn--secondary">
          {{ section.settings.cta_secondary_text }}
        </a>
        {% endif %}
      </div>
      <div class="rtl-hero__stats">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
          <div class="rtl-hero__stat">
            <span class="rtl-hero__stat-number">{{ block.settings.number }}</span>
            <span class="rtl-hero__stat-label">{{ block.settings.label }}</span>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="rtl-hero__visual">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="{{ section.settings.title }}" class="rtl-hero__image" loading="eager">
      {% else %}
        <div class="rtl-hero__placeholder">
          <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="50" y="30" width="180" height="260" rx="12" fill="#FAC775" opacity="0.9" transform="rotate(-8 140 160)"/>
            <rect x="80" y="50" width="180" height="260" rx="12" fill="#169380" opacity="0.9" transform="rotate(4 170 180)"/>
            <rect x="110" y="70" width="180" height="260" rx="12" fill="#0F7468" opacity="0.95" transform="rotate(-2 200 200)"/>
            <text x="155" y="180" fill="white" font-size="18" font-weight="bold" text-anchor="middle" font-family="Tajawal">READ</text>
            <text x="155" y="210" fill="#FAC775" font-size="22" font-weight="800" text-anchor="middle" font-family="Tajawal">TO LEAD</text>
          </svg>
        </div>
      {% endif %}
      <div class="rtl-hero__float rtl-hero__float--1"></div>
      <div class="rtl-hero__float rtl-hero__float--2"></div>
      <div class="rtl-hero__float rtl-hero__float--3"></div>
    </div>
  </div>
</section>

<style>
  .rtl-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #085041 0%, #0F7468 30%, #169380 60%, #1a9e8b 100%);
    padding: 80px 0 60px;
    direction: rtl;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .rtl-hero__bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 20% 50%, rgba(250,199,117,0.08) 0%, transparent 50%),
                      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.05) 0%, transparent 40%),
                      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .rtl-hero__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .rtl-hero__badge {
    display: inline-block;
    background: rgba(250,199,117,0.15);
    border: 1px solid rgba(250,199,117,0.3);
    color: #FAC775;
    padding: 6px 20px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    font-family: 'Tajawal', sans-serif;
    margin-bottom: 20px;
    backdrop-filter: blur(10px);
  }
  .rtl-hero__title {
    font-family: 'Tajawal', sans-serif !important;
    font-size: 48px;
    font-weight: 900;
    color: #ffffff;
    line-height: 1.3;
    margin: 0 0 16px;
  }
  .rtl-hero__title span {
    color: #FAC775;
  }
  .rtl-hero__subtitle {
    font-family: 'Tajawal', sans-serif !important;
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    line-height: 1.8;
    margin: 0 0 32px;
    max-width: 500px;
  }
  .rtl-hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .rtl-hero__btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 36px;
    border-radius: 12px;
    font-family: 'Tajawal', sans-serif !important;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .rtl-hero__btn--primary {
    background: linear-gradient(135deg, #FAC775, #EF9F27);
    color: #085041;
    box-shadow: 0 8px 30px rgba(250,199,117,0.35);
  }
  .rtl-hero__btn--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(250,199,117,0.5);
    color: #085041;
  }
  .rtl-hero__btn--secondary {
    background: rgba(255,255,255,0.1);
    color: #ffffff;
    border: 2px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(10px);
  }
  .rtl-hero__btn--secondary:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.5);
    color: #ffffff;
    transform: translateY(-2px);
  }
  .rtl-hero__stats {
    display: flex;
    gap: 40px;
  }
  .rtl-hero__stat {
    text-align: center;
  }
  .rtl-hero__stat-number {
    display: block;
    font-family: 'Tajawal', sans-serif !important;
    font-size: 32px;
    font-weight: 900;
    color: #FAC775;
    line-height: 1.2;
  }
  .rtl-hero__stat-label {
    display: block;
    font-family: 'Tajawal', sans-serif !important;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }
  .rtl-hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rtl-hero__image {
    max-width: 100%;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    animation: heroFloat 6s ease-in-out infinite;
  }
  .rtl-hero__placeholder svg {
    width: 100%;
    max-width: 400px;
    animation: heroFloat 6s ease-in-out infinite;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.25));
  }
  .rtl-hero__float {
    position: absolute;
    border-radius: 50%;
    animation: floatBubble 8s ease-in-out infinite;
  }
  .rtl-hero__float--1 {
    width: 80px; height: 80px;
    background: rgba(250,199,117,0.12);
    top: 10%; left: 10%;
    animation-delay: 0s;
  }
  .rtl-hero__float--2 {
    width: 50px; height: 50px;
    background: rgba(255,255,255,0.08);
    bottom: 20%; right: 5%;
    animation-delay: 2s;
  }
  .rtl-hero__float--3 {
    width: 30px; height: 30px;
    background: rgba(250,199,117,0.15);
    top: 60%; left: 60%;
    animation-delay: 4s;
  }
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  @keyframes floatBubble {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-20px) scale(1.1); opacity: 1; }
  }
  @media (max-width: 768px) {
    .rtl-hero { padding: 50px 0 40px; min-height: auto; }
    .rtl-hero__container { grid-template-columns: 1fr; gap: 30px; text-align: center; }
    .rtl-hero__title { font-size: 32px; }
    .rtl-hero__subtitle { font-size: 15px; margin: 0 auto 24px; }
    .rtl-hero__ctas { justify-content: center; }
    .rtl-hero__stats { justify-content: center; gap: 24px; }
    .rtl-hero__visual { order: -1; }
    .rtl-hero__image, .rtl-hero__placeholder svg { max-width: 280px; }
  }
</style>

{% schema %}
{
  "name": "RTL Hero",
  "tag": "section",
  "class": "rtl-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "🚀 منصة المعرفة العربية الأولى"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "اقرأ. تعلّم. <span>قُد.</span>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "حقائب معرفية مطبوعة + أدوات رقمية + ملخصات كتب. كل اللي محتاجه عشان تبني مشروعك وتطور مهاراتك — بالعربي."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA Text",
      "default": "تصفّح الحقائب"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA Text",
      "default": "حمّل التطبيق"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "+4,700"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "طلب"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RTL Hero",
      "blocks": [
        { "type": "stat", "settings": { "number": "+4,700", "label": "طلب" } },
        { "type": "stat", "settings": { "number": "+120", "label": "كتاب" } },
        { "type": "stat", "settings": { "number": "3", "label": "أسواق" } },
        { "type": "stat", "settings": { "number": "+2,300", "label": "ملخص" } }
      ]
    }
  ]
}
{% endschema %}