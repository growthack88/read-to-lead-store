<script>
(function(){
  var SHEET_URL = 'https://script.google.com/macros/s/AKfycbwZv3f324zLsSzuqZ2IUuv19hm-WINpmWllBzhQ6Q25jV_hGpoRHD2QuMPaNhpo7a5m1Q/exec';

  document.getElementById('f-phone').addEventListener('input',function(){
    this.value=this.value.replace(/\D/g,'');
  });

  function chk(id,eid,fn){
    var el=document.getElementById(id),ok=fn(el.value.trim());
    el.classList.toggle('err',!ok);
    document.getElementById(eid).classList.toggle('show',!ok);
    return ok;
  }

  document.getElementById('f-sub').addEventListener('click',function(){
    var valid=
      chk('f-name','e-name',function(v){return v.length>=3})&
      chk('f-phone','e-phone',function(v){return /^(010|011|012|015)\d{8}$/.test(v)})&
      chk('f-gov','e-gov',function(v){return v!==''})&
      chk('f-addr','e-addr',function(v){return v.length>=10});
    if(!valid) return;

    var btn=this;
    btn.disabled=true;
    document.getElementById('f-spin').style.display='inline-block';
    document.getElementById('f-txt').textContent='جارٍ إرسال الطلب…';

    var payload={
      name:    document.getElementById('f-name').value.trim(),
      phone:   document.getElementById('f-phone').value.trim(),
      gov:     document.getElementById('f-gov').value,
      address: document.getElementById('f-addr').value.trim(),
      product: '{{ product.title | default: "طريقك لبناء Startup" }}',
      price:   '{{ price }}'
    };

    fetch(SHEET_URL, {
      method:'POST',
      mode:'no-cors',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload)
    })
    .then(function(){ showSuccess(); })
    .catch(function(){
      /* still show success — no-cors doesn't return readable response */
      showSuccess();
    });
  });

  function showSuccess(){
    document.getElementById('form-body').style.display='none';
    var s=document.getElementById('success');
    s.style.display='flex';
    document.getElementById('s-name').textContent=document.getElementById('f-name').value;
    document.getElementById('s-phone').textContent=document.getElementById('f-phone').value;
    document.getElementById('s-gov').textContent=document.getElementById('f-gov').value;
  }

  /* scroll reveal */
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting) e.target.classList.add('in')});
  },{threshold:.08});
  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});

  /* FAQ accordion */
  document.querySelectorAll('.faq-q').forEach(function(q){
    q.addEventListener('click',function(){
      var item=q.parentElement,open=item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(i){i.classList.remove('open')});
      if(!open) item.classList.add('open');
    });
  });
})();
</script>
